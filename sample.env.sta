#
# Database
#
STA_DATABASE_NAME=sensorthings
STA_DATABASE_USER=sensorthings
# openssl rand -hex 64 | cut -c -64
STA_DATABASE_PASSWORD=
STA_DATABASE_HOST=sta-db
STA_DATABASE_PORT=5432
POSTGRES_DB=${STA_DATABASE_NAME}
POSTGRES_USER=${STA_DATABASE_USER}
POSTGRES_PASSWORD=${STA_DATABASE_PASSWORD}
#
# FROST-Server
#
# General Settings
FROST_CONTEXT_PATH=sensordata
#
# Provide a valid jq parseable json array with user objects.
#                                     applicable for mqtt/http:    both   both     http      http    http
# User: {"name":"username","password":"secret-password","roles": ["read","create","update","delete","admin"]}
#
#   https://fraunhoferiosb.github.io/FROST-Server/settings/auth.html#roles
#
FROST_USERS=[{"name":"admin","password":"admin","roles":["read","create","update","delete","admin"]},{"name":"read","password":"normal-pass","roles":["read"]}]
serviceRootUrl=http://localhost/${FROST_CONTEXT_PATH}

# Database for Persistence & Auth
persistence_db_driver=org.postgresql.Driver
persistence_db_url=jdbc:postgresql://${STA_DATABASE_HOST}:${STA_DATABASE_PORT}/${STA_DATABASE_NAME}
persistence_db_username=${STA_DATABASE_USER}
persistence_db_password=${STA_DATABASE_PASSWORD}
persistence_autoUpdateDatabase=true

#disable on production!
logSensitiveData=true

http_cors_enable=true
http_cors_allowed_origins=*

plugins_modelLoader_enable=true
plugins_multiDatastream_enable=false
plugins_actuation_enable=false

# Auth Provider Settings
auth_provider=de.fraunhofer.iosb.ilt.frostserver.auth.basic.BasicAuthProvider
auth_db_driver=org.postgresql.Driver
auth_db_url=jdbc:postgresql://${STA_DATABASE_HOST}:${STA_DATABASE_PORT}/${STA_DATABASE_NAME}
auth_db_username=${STA_DATABASE_USER}
auth_db_password=${STA_DATABASE_PASSWORD}
auth_plainTextPassword=false
# we create the schema and insert content based on $FROST_USERS
auth_autoUpdateDatabase=false
auth_realm_name=CoSite InfoTool STA

# MQTT Activation within the main image
mqtt_enabled=true
mqtt_Port=1883
mqtt_websocketPort=9876
